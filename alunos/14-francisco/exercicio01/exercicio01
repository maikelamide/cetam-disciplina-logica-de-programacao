Questão 3: Implementar no Visualg 
Escolha um algoritmo das questões anteriores para desenvolver, você pode copiar o 
código e colar aqui embaixo. 

algoritmo "media"

var
   nome: caractere
   nota1: real
   nota2: real
   media: real
inicio

   escreval("Digite o nome do aluno: ")
   leia(nome)

   escreval("Digite a primeira nota: ")
   leia(nota1)

   escreval("Digite a segunda nota: ")
   leia(nota2)

   media <- (nota1 + nota2) / 2

   escreval("Aluno: ", nome)
   escreval("Média final: ", media)

fimalgoritmo

